DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=
ALGOWIKI_RELEASE=dev
DJANGO_SERVE_FRONTEND=0
FRONTEND_DIST_DIR=
DJANGO_USE_X_FORWARDED_HOST=0
DJANGO_USE_X_FORWARDED_PORT=0
# Example: DJANGO_SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
DJANGO_SECURE_PROXY_SSL_HEADER=

# Database settings
# MySQL is the default/recommended engine for local + production.
DB_ENGINE=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=algowiki
DB_USER=root
DB_PASSWORD=replace-with-db-password
DB_CHARSET=utf8mb4
DB_CONN_MAX_AGE=60
# Optional, useful for strict SQL mode on server:
# DB_INIT_COMMAND=SET sql_mode='STRICT_TRANS_TABLES,NO_ENGINE_SUBSTITUTION'
# Optional, useful for cloud DB TLS:
# DB_SSL_CA=/path/to/ca.pem
# DB_SSL_CERT=/path/to/client-cert.pem
# DB_SSL_KEY=/path/to/client-key.pem

# optional for migration generation workflow
# MIGRATION_MODULES_WIKI=wiki.new_migrations

SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=replace-with-a-random-password
SUPERADMIN_EMAIL=admin@example.com

# auth hardening
AUTH_TOKEN_TTL_HOURS=168
LOGIN_MAX_FAILURES=5
LOGIN_FAILURE_WINDOW_MINUTES=15
LOGIN_LOCK_MINUTES=15
THROTTLE_LOGIN=20/hour
THROTTLE_REGISTER=10/hour
THROTTLE_REGISTER_CHALLENGE=30/hour
THROTTLE_REGISTER_VERIFY=20/hour
THROTTLE_PASSWORD_RESET_REQUEST=10/hour
THROTTLE_PASSWORD_RESET_CONFIRM=20/hour
THROTTLE_PASSWORD_CHANGE=6/hour
THROTTLE_EMAIL_CHANGE_REQUEST=10/hour
THROTTLE_EMAIL_CHANGE_CONFIRM=20/hour
THROTTLE_ASSISTANT_ANON=15/hour
THROTTLE_ASSISTANT_USER=60/hour
PASSWORD_HISTORY_COUNT=5
SITE_NAME=AlgoWiki
QA_MODULE_ENABLED=0
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=465
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=0
EMAIL_USE_SSL=1
EMAIL_TIMEOUT=10
DEFAULT_FROM_EMAIL=AlgoWiki <no-reply@example.com>
SERVER_EMAIL=no-reply@example.com
EMAIL_SUBJECT_PREFIX=[AlgoWiki]
EMAIL_CODE_TTL_SECONDS=600
EMAIL_CODE_LENGTH=6
EMAIL_CODE_RESEND_SECONDS=60
EMAIL_CODE_WINDOW_MINUTES=60
EMAIL_CODE_MAX_SENDS_PER_WINDOW=5
EMAIL_CODE_MAX_VERIFY_ATTEMPTS=5
PHONE_VERIFICATION_RESEND_SECONDS=60
PHONE_VERIFICATION_WINDOW_MINUTES=60
PHONE_VERIFICATION_MAX_SENDS_PER_WINDOW=5
PHONE_VERIFICATION_MAX_VERIFY_ATTEMPTS=5
SECURE_SSL_REDIRECT=1
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=1
SECURE_HSTS_PRELOAD=1
SESSION_COOKIE_SECURE=1
CSRF_COOKIE_SECURE=1
DJANGO_REQUEST_LOG_ENABLED=1
DJANGO_SLOW_REQUEST_MS=1500
DJANGO_LOG_LEVEL=INFO
# DJANGO_LOG_DIR=/path/to/project/storage/logs
# DJANGO_LOG_SQL_QUERIES=0
HEALTH_MIN_DISK_FREE_MB=512
DATA_UPLOAD_MAX_MEMORY_SIZE=10485760
FILE_UPLOAD_MAX_MEMORY_SIZE=4194304
DATA_UPLOAD_MAX_NUMBER_FIELDS=2000
IMAGE_UPLOAD_MAX_BYTES=8388608
IMAGE_UPLOAD_MAX_PIXELS=12000000
IMAGE_UPLOAD_MAX_WIDTH=4096
IMAGE_UPLOAD_MAX_HEIGHT=4096
IMAGE_UPLOAD_BURST_LIMIT=3
IMAGE_UPLOAD_BURST_WINDOW_SECONDS=60
IMAGE_UPLOAD_MIN_INTERVAL_SECONDS=10
IMAGE_UPLOAD_HOURLY_LIMIT=30
IMAGE_UPLOAD_DAILY_LIMIT=100
IMAGE_MODERATION_PROVIDER=disabled
ALIYUN_IMAGE_MODERATION_ENABLED=0
ALIYUN_IMAGE_MODERATION_ACCESS_KEY_ID=
ALIYUN_IMAGE_MODERATION_ACCESS_KEY_SECRET=
ALIYUN_IMAGE_MODERATION_ENDPOINTS=green.cn-shanghai.aliyuncs.com,green.cn-beijing.aliyuncs.com
ALIYUN_IMAGE_MODERATION_TIMEOUT_SECONDS=15
MEDIA_HOTLINK_PROTECTION=1
MEDIA_HOTLINK_PROTECTED_PREFIXES=moments
MEDIA_HOTLINK_ALLOWED_HOSTS=

# AI assistant
# If omitted, the backend will derive a stable encryption key from DJANGO_SECRET_KEY.
# For production, it is recommended to set an explicit random 32-byte urlsafe base64 key.
AI_ASSISTANT_ENCRYPTION_KEY=

# Aliyun financial-grade real-name verification.
# Keep disabled until the Aliyun product, Scene ID and credentials are ready.
ALIYUN_IDVERIFY_ENABLED=0
ALIYUN_IDVERIFY_ACCESS_KEY_ID=
ALIYUN_IDVERIFY_ACCESS_KEY_SECRET=
ALIYUN_IDVERIFY_SCENE_ID=
ALIYUN_IDVERIFY_PRODUCT_CODE=ID_PRO
ALIYUN_IDVERIFY_MODEL=MOVE_ACTION
ALIYUN_IDVERIFY_CERT_TYPE=IDENTITY_CARD
ALIYUN_IDVERIFY_CERTIFY_URL_TYPE=H5
ALIYUN_IDVERIFY_CERTIFY_URL_STYLE=
ALIYUN_IDVERIFY_PROCEDURE_PRIORITY=url
ALIYUN_IDVERIFY_ENDPOINTS=cloudauth.cn-shanghai.aliyuncs.com,cloudauth.cn-beijing.aliyuncs.com
# Leave blank to let backend derive /moments?real_name_return=1 from the current host.
ALIYUN_IDVERIFY_RETURN_URL=
# Optional Aliyun server callback URL, e.g. https://test.algowiki.cn/api/real-name-verifications/aliyun-callback/
ALIYUN_IDVERIFY_CALLBACK_URL=
ALIYUN_IDVERIFY_TIMEOUT_SECONDS=15

# Aliyun Phone Number Verification Service (PNVS) SMS verification.
# This replaces real-name verification as the default Moments access gate.
ALIYUN_PNVS_ENABLED=0
ALIYUN_PNVS_ACCESS_KEY_ID=
ALIYUN_PNVS_ACCESS_KEY_SECRET=
ALIYUN_PNVS_SIGN_NAME=速通互联验证码
ALIYUN_PNVS_TEMPLATE_CODE=100001
ALIYUN_PNVS_TEMPLATE_PARAM={"code":"##code##","min":"5"}
ALIYUN_PNVS_SCHEME_NAME=AlgoWiki
ALIYUN_PNVS_COUNTRY_CODE=86
ALIYUN_PNVS_CODE_LENGTH=6
ALIYUN_PNVS_VALID_TIME_SECONDS=300
ALIYUN_PNVS_INTERVAL_SECONDS=60
ALIYUN_PNVS_CODE_TYPE=1
ALIYUN_PNVS_DUPLICATE_POLICY=1
ALIYUN_PNVS_RETURN_VERIFY_CODE=0
ALIYUN_PNVS_ENDPOINTS=dypnsapi.aliyuncs.com
ALIYUN_PNVS_TIMEOUT_SECONDS=15
