# AlgoWiki production environment example.
# Copy to deploy/.env.production and replace every <PLACEHOLDER>.

APP_ENV_FILE=deploy/.env.production
COMPOSE_PROJECT_NAME=algowiki
APP_IMAGE=ghcr.io/<GITHUB_OWNER>/algowiki-web:latest
APP_IMAGE_REPOSITORY=ghcr.io/<GITHUB_OWNER>/algowiki-web
GITHUB_REPOSITORY=<GITHUB_OWNER>/<GITHUB_REPO>
GITHUB_BRANCH=main
DEPLOY_SYNC_GITHUB_BRANCH=0
MYSQL_IMAGE=mysql:8.4

DJANGO_DEBUG=0
DJANGO_SECRET_KEY=<DJANGO_SECRET_KEY>
DJANGO_ALLOWED_HOSTS=<APEX_DOMAIN>,<WWW_DOMAIN>,127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=https://<APEX_DOMAIN>,https://<WWW_DOMAIN>
ALGOWIKI_RELEASE=production
DJANGO_SERVE_FRONTEND=1
DJANGO_USE_X_FORWARDED_HOST=1
DJANGO_USE_X_FORWARDED_PORT=1
DJANGO_SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
SECURE_SSL_REDIRECT=1
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=1
SECURE_HSTS_PRELOAD=1
SESSION_COOKIE_SECURE=1
CSRF_COOKIE_SECURE=1

APP_BIND=127.0.0.1
APP_PORT=8001
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=120
DB_WAIT_TIMEOUT=120
DB_WAIT_INTERVAL=2

DJANGO_REQUEST_LOG_ENABLED=1
DJANGO_SLOW_REQUEST_MS=1500
DJANGO_LOG_LEVEL=INFO
DJANGO_LOG_DIR=/srv/algowiki/storage/logs
HEALTH_MIN_DISK_FREE_MB=1024

DATA_UPLOAD_MAX_MEMORY_SIZE=10485760
FILE_UPLOAD_MAX_MEMORY_SIZE=4194304
DATA_UPLOAD_MAX_NUMBER_FIELDS=2000
IMAGE_UPLOAD_MAX_BYTES=8388608
IMAGE_UPLOAD_MAX_REQUEST_BYTES=20971520
IMAGE_UPLOAD_MAX_PIXELS=12000000
IMAGE_UPLOAD_MAX_WIDTH=4096
IMAGE_UPLOAD_MAX_HEIGHT=4096
IMAGE_UPLOAD_BURST_LIMIT=3
IMAGE_UPLOAD_BURST_WINDOW_SECONDS=60
IMAGE_UPLOAD_MIN_INTERVAL_SECONDS=10
IMAGE_UPLOAD_HOURLY_LIMIT=30
IMAGE_UPLOAD_DAILY_LIMIT=100
IMAGE_UPLOAD_IP_HOURLY_LIMIT=120
IMAGE_UPLOAD_IP_DAILY_LIMIT=400
IMAGE_UPLOAD_IP_HOURLY_BYTES=134217728
IMAGE_UPLOAD_IP_DAILY_BYTES=536870912
MOMENT_IMAGE_THUMBNAIL_MAX_SIDE=480
MOMENT_IMAGE_THUMBNAIL_MAX_BYTES=184320
MOMENT_IMAGE_REJECTED_RETENTION_DAYS=30

IMAGE_MODERATION_PROVIDER=disabled
ALIYUN_IMAGE_MODERATION_ENABLED=0
ALIYUN_IMAGE_MODERATION_ACCESS_KEY_ID=<ALIYUN_ACCESS_KEY_ID>
ALIYUN_IMAGE_MODERATION_ACCESS_KEY_SECRET=<ALIYUN_ACCESS_KEY_SECRET>
ALIYUN_IMAGE_MODERATION_ENDPOINTS=green.cn-shanghai.aliyuncs.com,green.cn-beijing.aliyuncs.com
ALIYUN_IMAGE_MODERATION_TIMEOUT_SECONDS=15

MEDIA_HOTLINK_PROTECTION=1
MEDIA_HOTLINK_PROTECTED_PREFIXES=moments,moments-thumbs,avatars
MEDIA_HOTLINK_ALLOWED_HOSTS=<APEX_DOMAIN>,<WWW_DOMAIN>

REGISTER_CAPTCHA_TTL_SECONDS=600
EMAIL_CODE_TTL_SECONDS=600
EMAIL_CODE_LENGTH=6
EMAIL_CODE_RESEND_SECONDS=60
EMAIL_CODE_WINDOW_MINUTES=60
EMAIL_CODE_MAX_SENDS_PER_WINDOW=5
EMAIL_CODE_MAX_VERIFY_ATTEMPTS=5
PHONE_VERIFICATION_RESEND_SECONDS=60
PHONE_VERIFICATION_WINDOW_MINUTES=60
PHONE_VERIFICATION_MAX_SENDS_PER_WINDOW=5
PHONE_VERIFICATION_MAX_VERIFY_ATTEMPTS=5

THROTTLE_LOGIN=3/min
THROTTLE_REGISTER=3/hour
THROTTLE_REGISTER_CHALLENGE=12/min
THROTTLE_REGISTER_VERIFY=12/hour
THROTTLE_PASSWORD_RESET_REQUEST=6/hour
THROTTLE_PASSWORD_RESET_CONFIRM=12/hour
THROTTLE_PASSWORD_CHANGE=3/hour
THROTTLE_EMAIL_CHANGE_REQUEST=6/hour
THROTTLE_EMAIL_CHANGE_CONFIRM=12/hour
THROTTLE_PROFILE_UPDATE=3/min
THROTTLE_CONTENT_CREATE=3/min
THROTTLE_CONTENT_UPDATE=3/min
THROTTLE_CONTENT_DELETE=3/min

SITE_NAME=AlgoWiki
QA_MODULE_ENABLED=0
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=<SMTP_HOST>
EMAIL_PORT=465
EMAIL_HOST_USER=<SMTP_USER>
EMAIL_HOST_PASSWORD=<SMTP_PASSWORD>
EMAIL_USE_TLS=0
EMAIL_USE_SSL=1
EMAIL_TIMEOUT=10
DEFAULT_FROM_EMAIL=AlgoWiki <sender@example.com>
SERVER_EMAIL=sender@example.com
EMAIL_SUBJECT_PREFIX=[AlgoWiki]

DB_ENGINE=mysql
DB_HOST=<DB_HOST>
DB_PORT=3306
DB_NAME=algowiki
DB_USER=<DB_USER>
DB_PASSWORD=<DB_PASSWORD>
DB_CHARSET=utf8mb4
DB_CONN_MAX_AGE=300
# Optional for RDS TLS:
# DB_SSL_CA=/etc/ssl/certs/rds-ca.pem

MEDIA_ROOT=/srv/algowiki/media
MEDIA_URL=/media/
FRONTEND_DIST_DIR=/srv/algowiki/frontend/dist
PUBLIC_SITE_URL=https://<WWW_DOMAIN>
PUBLIC_APEX_URL=https://<APEX_DOMAIN>

ALIYUN_IDVERIFY_ENABLED=0
ALIYUN_IDVERIFY_ACCESS_KEY_ID=<ALIYUN_ACCESS_KEY_ID>
ALIYUN_IDVERIFY_ACCESS_KEY_SECRET=<ALIYUN_ACCESS_KEY_SECRET>
ALIYUN_IDVERIFY_SCENE_ID=<ALIYUN_IDVERIFY_SCENE_ID>
ALIYUN_IDVERIFY_PRODUCT_CODE=ID_PRO
ALIYUN_IDVERIFY_MODEL=MOVE_ACTION
ALIYUN_IDVERIFY_CERT_TYPE=IDENTITY_CARD
ALIYUN_IDVERIFY_CERTIFY_URL_TYPE=H5
ALIYUN_IDVERIFY_CERTIFY_URL_STYLE=
ALIYUN_IDVERIFY_PROCEDURE_PRIORITY=url
ALIYUN_IDVERIFY_ENDPOINTS=cloudauth.cn-shanghai.aliyuncs.com,cloudauth.cn-beijing.aliyuncs.com
ALIYUN_IDVERIFY_RETURN_URL=https://<WWW_DOMAIN>/moments?real_name_return=1
ALIYUN_IDVERIFY_CALLBACK_URL=https://<WWW_DOMAIN>/api/real-name-verifications/aliyun-callback/
ALIYUN_IDVERIFY_TIMEOUT_SECONDS=15

ALIYUN_PNVS_ENABLED=0
ALIYUN_PNVS_ACCESS_KEY_ID=<ALIYUN_ACCESS_KEY_ID>
ALIYUN_PNVS_ACCESS_KEY_SECRET=<ALIYUN_ACCESS_KEY_SECRET>
ALIYUN_PNVS_SIGN_NAME=<SMS_SIGN_NAME>
ALIYUN_PNVS_TEMPLATE_CODE=<SMS_TEMPLATE_CODE>
ALIYUN_PNVS_TEMPLATE_PARAM={"code":"##code##","min":"5"}
ALIYUN_PNVS_SCHEME_NAME=AlgoWiki
ALIYUN_PNVS_COUNTRY_CODE=86
ALIYUN_PNVS_CODE_LENGTH=6
ALIYUN_PNVS_VALID_TIME_SECONDS=300
ALIYUN_PNVS_INTERVAL_SECONDS=60
ALIYUN_PNVS_CODE_TYPE=1
ALIYUN_PNVS_DUPLICATE_POLICY=1
ALIYUN_PNVS_RETURN_VERIFY_CODE=0
ALIYUN_PNVS_ENDPOINTS=dypnsapi.aliyuncs.com
ALIYUN_PNVS_TIMEOUT_SECONDS=15

SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=<SUPERADMIN_PASSWORD>
SUPERADMIN_EMAIL=<SUPERADMIN_EMAIL>
